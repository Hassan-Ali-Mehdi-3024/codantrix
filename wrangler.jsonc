{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "codantrix-labs",
  "main": "worker/index.ts",
  "compatibility_date": "2026-02-03",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": "./site",
    "binding": "ASSETS",
    "not_found_handling": "404-page",
    "html_handling": "auto-trailing-slash",
    "run_worker_first": ["/api/*"]
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "codantrix-labs-db",
      "database_id": "1ecd521a-1017-45b9-ab90-1e1ce4aca9ae"
    }
  ],
  "vars": {
    // Provider: Groq direct (https://api.groq.com/openai/v1) — OpenAI-compatible.
    // Model: llama-3.3-70b-versatile.
    //
    // Why Groq direct after a day of OpenRouter trials:
    //   morning: Groq llama-3.1-8b-instant (TPM rate-limited under test burst)
    //   noon:    OpenRouter google/gemma-4-31b-it:free (Google AI Studio shared
    //            pool returned upstream 429s)
    //   pm:      OpenRouter meta-llama/llama-3.3-70b-instruct:free (Venice
    //            shared pool returned upstream 429s)
    //   evening: Groq llama-3.3-70b-versatile (this) — direct provider, our
    //            own free quota (12K TPM, 14.4K RPD), no shared pool.
    //
    // For a low-volume /book widget (1 visitor at a time, ~1 message per 30s)
    // the 12K TPM cap is actually fine. If volume justifies it later, switch
    // to Groq Dev tier (paid) or revisit OpenRouter with a private provider
    // key (https://openrouter.ai/settings/integrations) to bypass shared pools.
    "LLM_MODEL": "llama-3.3-70b-versatile"
  }
  // Secrets (set via `wrangler secret put`, NOT here):
  //   LLM_API_KEY     — OpenRouter API key (was GROQ_API_KEY pre-2026-04-26)
  //   CALENDLY_TOKEN  — Calendly Personal Access Token (optional)
}
