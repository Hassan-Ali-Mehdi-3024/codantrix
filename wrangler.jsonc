{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "codantrix-labs",
  "main": "worker/index.ts",
  "compatibility_date": "2026-02-03",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": "./site",
    "binding": "ASSETS",
    "not_found_handling": "404-page",
    "html_handling": "auto-trailing-slash"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "codantrix-labs-db",
      "database_id": "REPLACE_WITH_ID_FROM_WRANGLER_D1_CREATE"
    }
  ],
  "vars": {
    "GROQ_MODEL": "llama-3.3-70b-versatile"
  }
  // Secrets (set via `wrangler secret put`, NOT here):
  //   GROQ_API_KEY     — Phase 3, when /api/chat goes live
  //   CALENDLY_TOKEN   — Phase 3, when book_call/check_availability tools land
}
